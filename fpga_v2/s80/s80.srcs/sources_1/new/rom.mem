@0000
11 FF 7F    // ld de, $7FFF
AF          // xor a,a
13          // inc de
C3 08 00    // jp $0008
3E 03       // ld a,3
3E 02       // ld a,2
3D          // dec a
20 FD       // jr nz, -3
00          // nop
2E 01       // ld l,$01
26 80       // ld h,$80
77          // ld [hl],a
3C          // inc a
18 FD       // jr -3